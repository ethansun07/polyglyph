# Copy to .env and fill in values. Never commit .env.
PORT=3001

# Postgres (local dev defaults — no password needed on Mac)
DB_HOST=localhost
DB_NAME=amharic_fidel
DB_USER=ethansun
DB_PASSWORD=
DB_PORT=5432

# In production (e.g. Render), set DATABASE_URL instead of the DB_* vars above.
# It takes priority over them when present.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Comma-separated list of origins allowed to call this API.
# In production, set this to your deployed frontend's URL.
CORS_ORIGIN=http://localhost:5173
